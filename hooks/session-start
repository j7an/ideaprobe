#!/bin/bash
set -euo pipefail

# Resolve the plugin root directory (one level up from hooks/)
PLUGIN_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SKILL_FILE="$PLUGIN_ROOT/skills/using-ideaprobe/SKILL.md"

# Exit silently if the skill file doesn't exist
if [ ! -f "$SKILL_FILE" ]; then
  exit 0
fi

# Read the skill file and strip YAML frontmatter
# (removes everything between the first pair of --- lines)
CONTENT=$(sed -n '/^---$/,/^---$/!p' "$SKILL_FILE")

# JSON-escape the content using Python
# Handles newlines, quotes, backslashes, and special characters
ESCAPED=$(printf '%s' "$CONTENT" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))')

# Output for Claude Code injection
# Claude Code reads hookSpecificOutput.additionalContext
cat <<JSONEOF
{
  "hookSpecificOutput": {
    "additionalContext": $ESCAPED
  }
}
JSONEOF
